{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "rgbds",
      "camelcase": "RGBDS",
      "title": "Rednex GameBoy Development System",
      "scope": "source.rgbds",
      "file-types": [
        "asm",
        "z80",
        "inc"
      ],
      "injection-regex": "^rgbds$",
      "class-name": "TreeSitterRgbds"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Rednex GameBoy Development System (RGBDS) grammar for Tree Sitter",
    "authors": [
      {
        "name": "dr4ghs",
        "email": "alvise.gorinati@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/dr4ghs/tree-sitter-rgbds",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}