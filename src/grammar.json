{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "rgbds",
  "rules": {
    "program": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_item"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "REPEAT1",
                    "content": {
                      "type": "STRING",
                      "value": "\n"
                    }
                  },
                  {
                    "type": "SYMBOL",
                    "name": "_item"
                  }
                ]
              }
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "REPEAT1",
                  "content": {
                    "type": "STRING",
                    "value": "\n"
                  }
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          ]
        },
        {
          "type": "BLANK"
        }
      ]
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "label"
        },
        {
          "type": "SYMBOL",
          "name": "section"
        },
        {
          "type": "SYMBOL",
          "name": "stack"
        }
      ]
    },
    "label": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_global_label"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "STRING",
                  "value": ":"
                },
                {
                  "type": "STRING",
                  "value": "::"
                }
              ]
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_local_label"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": ":"
                    },
                    {
                      "type": "STRING",
                      "value": "::"
                    }
                  ]
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          ]
        }
      ]
    },
    "_global_label": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_$#]+"
    },
    "_local_label": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_global_label"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\.[a-z0-9_]+"
        }
      ]
    },
    "section": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_section_start"
        },
        {
          "type": "SYMBOL",
          "name": "_section_end"
        }
      ]
    },
    "_section_start": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "SECTION"
        },
        {
          "type": "SYMBOL",
          "name": "section_name"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": ","
            },
            {
              "type": "SYMBOL",
              "name": "section_type"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "REPEAT",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": ","
                  },
                  {
                    "type": "SYMBOL",
                    "name": "section_option"
                  }
                ]
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_section_end": {
      "type": "STRING",
      "value": "ENDSECTION"
    },
    "section_name": {
      "type": "PATTERN",
      "value": "\"[^\"]*\""
    },
    "section_type": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "ROM[0X]"
            },
            {
              "type": "PATTERN",
              "value": "WRAM[0X]"
            },
            {
              "type": "PATTERN",
              "value": "[VSH]RAM"
            },
            {
              "type": "STRING",
              "value": "OAM"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_section_address"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_section_address": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "PATTERN",
          "value": "\\$[a-fA-F0-9]{1,4}"
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "section_option": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_section_bank_opt"
        },
        {
          "type": "SYMBOL",
          "name": "_section_align_opt"
        }
      ]
    },
    "_section_bank_opt": {
      "type": "PATTERN",
      "value": "BANK\\[[0-9]+\\]"
    },
    "_section_align_opt": {
      "type": "PATTERN",
      "value": "ALIGN\\[[0-9]+(, ?[0-9]+)?\\]"
    },
    "stack": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "PUSHS"
            },
            {
              "type": "PATTERN",
              "value": "\"[^\"]*\""
            },
            {
              "type": "SYMBOL",
              "name": "section_type"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "POPS"
        }
      ]
    },
    "string": {
      "type": "PATTERN",
      "value": "\"[^\"]*\""
    },
    "number": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "[0-9][0-9_]*"
        },
        {
          "type": "PATTERN",
          "value": "(\\$|0[Xx])[a-fA-F0-9][a-fA-F0-9_]*"
        },
        {
          "type": "PATTERN",
          "value": "(&|0[Oo])[0-7][0-7_]*"
        },
        {
          "type": "PATTERN",
          "value": "(%|0[Bb][01][01_]*)"
        },
        {
          "type": "PATTERN",
          "value": "[0-9][0-9_]*.[0-9][0-9_]*"
        },
        {
          "type": "PATTERN",
          "value": "[0-9][0-9_]*.[0-9][0-9_]*([qQ][0-9]+)?"
        },
        {
          "type": "PATTERN",
          "value": "."
        },
        {
          "type": "PATTERN",
          "value": "`[0-3][0-3_]{,7}*"
        }
      ]
    },
    "_addr": {
      "type": "PATTERN",
      "value": "\\$[0-9]{1,4}"
    },
    "comment": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_line_comment"
        },
        {
          "type": "SYMBOL",
          "name": "_block_comment"
        }
      ]
    },
    "_line_comment": {
      "type": "PATTERN",
      "value": ";.*"
    },
    "_block_comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "/*"
          },
          {
            "type": "PATTERN",
            "value": "[^*]*\\*+([^/*][^*]*\\*+)*"
          },
          {
            "type": "STRING",
            "value": "/"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": " |\\t|\\r"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}