  (section))

==========
VRAM section on BANK 1
==========
SECTION "VRAM Data", VRAM, BANK[1]
---
(program
  (section))

==========
VRAM section on BANK 0 w/ ALIGN
==========
SECTION "VRAM Data", VRAM, BANK[1], ALIGN[16]
---
(program
  (section))

==========
Explicit end section
==========
SECTION "Save Data", SRAM
; Set save data here
ENDSECTION
